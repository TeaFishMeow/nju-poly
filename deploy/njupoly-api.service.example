[Unit]
Description=NJUPoly FastAPI
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/root/njupoly
Environment=NJUPOLY_API_HOST=127.0.0.1
Environment=NJUPOLY_API_PORT=8000
ExecStart=/root/njupoly/deploy/api-start.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
