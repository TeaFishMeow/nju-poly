# Copy this to /path/to/njupoly/.local/server-env.sh on the server if the
# process manager does not set these variables directly.
NJUPOLY_ROOT=/root/njupoly

export PATH="$NJUPOLY_ROOT/.tools/bin:$PATH"
export PNPM_HOME="$NJUPOLY_ROOT/.tools/pnpm-home"
export PNPM_STORE_DIR="$NJUPOLY_ROOT/.pnpm-store"
export UV_CACHE_DIR="$NJUPOLY_ROOT/.cache/uv"
export UV_PYTHON_INSTALL_DIR="$NJUPOLY_ROOT/.cache/uv-python"
