{
  "name": "@njupoly/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ../../scripts/ensure-api-local.mjs && uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "migrate": "uv run alembic upgrade head",
    "start": "uv run uvicorn app.main:app --host 127.0.0.1 --port 8000",
    "generate-art": "uv run python scripts/generate_goal7_art.py",
    "verify-art": "uv run python scripts/verify_goal7_art.py",
    "lint": "uv run python -m compileall app",
    "test": "uv run pytest",
    "typecheck": "uv run python -m compileall app"
  }
}
